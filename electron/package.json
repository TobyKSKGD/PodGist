{
  "name": "podgist-desktop",
  "version": "1.0.0",
  "description": "PodGist 桌面应用 - 本地算力驱动的 AI 音频提炼工具",
  "author": "PodGist Team",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron-builder --dir",
    "build": "electron-builder --config electron-builder.yml",
    "build:win": "electron-builder --config electron-builder.yml --win",
    "build:mac": "electron-builder --config electron-builder.yml --mac",
    "build:all": "electron-builder --config electron-builder.yml --win --mac",
    "build:full": "BUILD_TYPE=full electron-builder --config electron-builder.yml --win",
    "build:lite": "BUILD_TYPE=lite electron-builder --config electron-builder.yml --win",
    "build:mac:lite": "BUILD_TYPE=lite npm run build:mac",
    "upload:release": "electron-builder --config electron-builder.yml --win --mac --publish always"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
